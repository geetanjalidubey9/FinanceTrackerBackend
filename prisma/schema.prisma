generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  VIEWER
  MANAGER
  ANALYST
}

enum Status {
  ACTIVE
  INACTIVE
}

model User {
  id               Int               @id @default(autoincrement())
  name             String
  email            String            @unique
  role             UserRole
  status           Status            @default(ACTIVE)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  financialRecords FinancialRecord[]
}

model FinancialRecord {
  id          Int      @id @default(autoincrement())
  amount      Float
  type        String   
  category    String
  date        DateTime
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
}